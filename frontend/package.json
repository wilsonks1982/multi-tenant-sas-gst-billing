{
  "name": "gst-billing-frontend",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "start": "webpack serve --mode development --open",
    "build": "webpack --mode development",
    "build:watch": "webpack --mode development --watch",
    "clean:spring": "shx rm -rf ../src/main/resources/static/*",
    "copy:spring": "copyfiles -u 1 dist/**/* ../src/main/resources/static && node -e \"console.log('[Frontend Sync]', new Date().toLocaleString(), 'copied to Spring static')\"",
    "watch:copy": "chokidar \"dist/**/*\" -c \"npm run copy:spring\"",
    "build:spring": "npm run build && npm run clean:spring && npm run copy:spring",
    "watch:build": "concurrently \"npm run build:watch\" \"npm run watch:copy\""
  },
  "engines": {
    "node": ">=20 <=22",
    "npm": ">=10"
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.1.1",
    "@chakra-ui/react": "^2.8.2",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@reduxjs/toolkit": "^2.2.7",
    "axios": "^1.7.2",
    "chakra-react-select": "^5.1.1",
    "framer-motion": "^11.3.19",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.26.0",
    "react-select": "^5.10.2",
    "redux-logger": "^3.0.6"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.4",
    "@babel/preset-react": "^7.24.7",
    "babel-loader": "^9.1.3",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.0.1",
    "copyfiles": "^2.4.1",
    "html-webpack-plugin": "^5.6.0",
    "shx": "^0.3.4",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
